<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no, viewport-fit=cover">
    <meta name="theme-color" content="#0a0a0a">
    <title>ORDEM PARANORMAL - RPG MOBILE V8</title>
    <style>
        /* ===== ESTILOS COMPLETOS (IGUAL AO V7) ===== */
        @import url('https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Courier+Prime:wght@400;700&display=swap');
        
        :root {
            --dark: #080808;
            --paper: #0f0f0f;
            --surface: #1a1a1a;
            --text: #f0f0f0;
            --text-muted: #777;
            --border: #333;
            
            --sangue: #8B0000;
            --sangue-light: #ff1a1a;
            --sangue-glow: rgba(139,0,0,0.6);
            --morte: #2a2a2a;
            --morte-light: #888;
            --morte-glow: rgba(40,40,40,0.8);
            --conhecimento: #DAA520;
            --conhecimento-light: #FFD700;
            --conhecimento-glow: rgba(218,165,32,0.5);
            --energia: #9400D3;
            --energia-light: #da70d6;
            --energia-glow: rgba(148,0,211,0.6);
            --medo: #f0f0f0;
            --medo-light: #fff;
            --medo-glow: rgba(255,255,255,0.4);
            
            --pv: #dc143c;
            --pe: #4169e1;
            --san: #2e8b57;
            
            --safe-top: env(safe-area-inset-top, 0px);
            --safe-bottom: env(safe-area-inset-bottom, 0px);
        }
        
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            -webkit-tap-highlight-color: transparent;
            touch-action: manipulation;
        }
        
        html { font-size: 16px; height: 100%; }
        
        body {
            font-family: 'Courier Prime', monospace;
            background: var(--dark);
            color: var(--text);
            line-height: 1.4;
            min-height: 100vh;
            overflow-x: hidden;
            transition: all 0.5s ease;
        }
        
        body.san-low { animation: glitch 0.3s infinite; }
        body.san-critical { animation: glitch 0.1s infinite; filter: contrast(1.2) brightness(0.8); }
        
        @keyframes glitch {
            0%, 100% { transform: translate(0); }
            20% { transform: translate(-2px, 2px); }
            40% { transform: translate(-2px, -2px); }
            60% { transform: translate(2px, 2px); }
            80% { transform: translate(2px, -2px); }
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
        @keyframes barFill { from { width: 0%; } }
        
        .bg-sangue { background: radial-gradient(circle at 50% 0%, rgba(139,0,0,0.4), transparent 70%), var(--dark); }
        .bg-morte { background: radial-gradient(circle at 50% 0%, rgba(40,40,40,0.6), transparent 70%), var(--dark); }
        .bg-conhecimento { background: radial-gradient(circle at 50% 0%, rgba(218,165,32,0.3), transparent 70%), var(--dark); }
        .bg-energia { background: radial-gradient(circle at 50% 0%, rgba(148,0,211,0.4), transparent 70%), var(--dark); }
        .bg-medo { background: radial-gradient(circle at 50% 0%, rgba(255,255,255,0.2), transparent 70%), var(--dark); }
        
        .symbol-bg {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 80vh;
            opacity: 0.03;
            pointer-events: none;
            z-index: 0;
            font-family: 'Cinzel', serif;
            animation: rotate 60s linear infinite;
        }
        
        @keyframes rotate {
            from { transform: translate(-50%, -50%) rotate(0deg); }
            to { transform: translate(-50%, -50%) rotate(360deg); }
        }
        
        .app-container {
            position: relative;
            z-index: 1;
            min-height: 100vh;
            padding-bottom: calc(100px + var(--safe-bottom));
        }
        
        .app-header {
            position: sticky;
            top: 0;
            z-index: 100;
            background: linear-gradient(180deg, var(--dark) 0%, transparent 100%);
            padding: calc(12px + var(--safe-top)) 16px 12px;
            text-align: center;
            backdrop-filter: blur(10px);
        }
        
        .app-title {
            font-family: 'Cinzel', serif;
            font-size: 1.2rem;
            letter-spacing: 4px;
            text-shadow: 0 0 20px currentColor;
            margin-bottom: 4px;
        }
        
        .app-subtitle {
            font-size: 0.6rem;
            letter-spacing: 3px;
            opacity: 0.6;
        }
        
        .char-selector {
            display: flex;
            gap: 12px;
            padding: 12px 16px;
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
            scrollbar-width: none;
        }
        
        .char-selector::-webkit-scrollbar { display: none; }
        
        .char-tab {
            flex-shrink: 0;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            border: 2px solid var(--border);
            background: var(--surface);
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Cinzel', serif;
            font-size: 1.5rem;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .char-tab.active {
            border-color: currentColor;
            box-shadow: 0 0 20px currentColor;
            transform: scale(1.1);
        }
        
        .char-tab img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .char-avatar {
            width: 100%;
            height: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
        }
        
        .char-add {
            border-style: dashed;
            font-size: 1.8rem;
            color: var(--text-muted);
        }
        
        .action-bar {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 8px;
            padding: 0 16px 16px;
        }
        
        .action-btn {
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px 4px;
            color: var(--text);
            font-size: 0.65rem;
            font-weight: 700;
            letter-spacing: 0.5px;
            text-transform: uppercase;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .action-btn:active { transform: scale(0.95); }
        .action-btn.primary { border-color: var(--sangue); color: var(--sangue-light); }
        .action-btn.secondary { border-color: var(--conhecimento); color: var(--conhecimento-light); }
        .action-btn.accent { border-color: var(--energia); color: var(--energia-light); }
        .action-btn.danger { border-color: var(--sangue); color: var(--sangue-light); }
        
        .data-actions {
            display: flex;
            gap: 8px;
            padding: 0 16px 16px;
            flex-wrap: wrap;
        }
        
        .data-btn {
            flex: 1;
            min-width: 70px;
            padding: 10px 8px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            font-size: 0.7rem;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .data-btn:hover { border-color: currentColor; }
        .data-btn.danger { border-color: var(--sangue); color: var(--sangue-light); }
        
        .sheet-container { padding: 0 16px; }
        
        .sheet {
            display: none;
            animation: fadeIn 0.4s;
        }
        
        .sheet.active { display: block; }
        
        .identity-card {
            background: linear-gradient(145deg, var(--surface), var(--paper));
            border: 1px solid var(--border);
            border-radius: 20px;
            padding: 20px;
            margin-bottom: 16px;
            position: relative;
            overflow: hidden;
        }
        
        .photo-upload {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            border: 3px solid currentColor;
            margin: 0 auto 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            overflow: hidden;
            cursor: pointer;
            background: var(--paper);
            box-shadow: 0 0 30px currentColor;
            transition: all 0.3s;
        }
        
        .photo-upload:hover { transform: scale(1.05); }
        
        .photo-upload img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        
        .photo-upload input {
            position: absolute;
            opacity: 0;
            width: 100%;
            height: 100%;
            cursor: pointer;
        }
        
        .photo-placeholder {
            font-size: 3rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
        }
        
        .photo-hint {
            font-size: 0.6rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .char-name {
            width: 100%;
            background: transparent;
            border: none;
            border-bottom: 2px solid currentColor;
            color: #fff;
            font-family: 'Cinzel', serif;
            font-size: 1.4rem;
            text-align: center;
            padding: 8px;
            margin-bottom: 12px;
        }
        
        .char-name:focus { outline: none; }
        
        .char-meta {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 8px;
        }
        
        .meta-field {
            background: rgba(0,0,0,0.3);
            border: 1px solid var(--border);
            border-radius: 8px;
            padding: 8px;
        }
        
        .meta-label {
            font-size: 0.6rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 4px;
        }
        
        .meta-input {
            width: 100%;
            background: transparent;
            border: none;
            color: var(--text);
            font-size: 0.9rem;
            font-family: 'Courier Prime', monospace;
        }
        
        .meta-input:focus { outline: none; }
        
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-bottom: 16px;
        }
        
        .stat-card {
            background: linear-gradient(145deg, var(--surface), var(--paper));
            border-radius: 16px;
            padding: 16px;
            position: relative;
            overflow: hidden;
        }
        
        .stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
        }
        
        .stat-card.pv::before { background: var(--pv); box-shadow: 0 0 10px var(--pv); }
        .stat-card.pe::before { background: var(--pe); box-shadow: 0 0 10px var(--pe); }
        .stat-card.san::before { background: var(--san); box-shadow: 0 0 10px var(--san); }
        .stat-card.def::before { background: var(--text-muted); }
        
        .stat-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 12px;
        }
        
        .stat-icon { font-size: 1.2rem; }
        
        .stat-name {
            font-size: 0.7rem;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .stat-values {
            display: flex;
            align-items: baseline;
            justify-content: center;
            gap: 4px;
            margin-bottom: 12px;
        }
        
        .stat-current {
            width: 50px;
            background: transparent;
            border: none;
            color: #fff;
            font-size: 2rem;
            font-weight: 700;
            text-align: center;
            font-family: 'Courier Prime', monospace;
        }
        
        .stat-sep { color: #444; }
        
        .stat-max {
            width: 35px;
            background: transparent;
            border: none;
            color: #666;
            font-size: 1rem;
            text-align: center;
            font-family: 'Courier Prime', monospace;
        }
        
        .stat-bar-bg {
            height: 8px;
            background: rgba(0,0,0,0.5);
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 12px;
        }
        
        .stat-bar {
            height: 100%;
            border-radius: 4px;
            transition: width 0.6s ease, background 0.3s;
            animation: barFill 0.8s ease;
        }
        
        .pv-bar { background: linear-gradient(90deg, #500, var(--pv)); }
        .pe-bar { background: linear-gradient(90deg, #1a237e, var(--pe)); }
        .san-bar { background: linear-gradient(90deg, #1b5e20, var(--san)); }
        
        .stat-controls {
            display: flex;
            justify-content: center;
            gap: 16px;
        }
        
        .stat-btn {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            color: var(--text);
            font-size: 1.2rem;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
        }
        
        .stat-btn:active {
            background: rgba(255,255,255,0.1);
            transform: scale(0.9);
        }
        
        .section {
            background: linear-gradient(145deg, var(--surface), var(--paper));
            border: 1px solid var(--border);
            border-radius: 16px;
            margin-bottom: 12px;
            overflow: hidden;
        }
        
        .section-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 20px;
            cursor: pointer;
            background: rgba(0,0,0,0.2);
        }
        
        .section-title {
            font-family: 'Cinzel', serif;
            font-size: 0.9rem;
            letter-spacing: 2px;
        }
        
        .section-arrow { transition: transform 0.3s; }
        .section.open .section-arrow { transform: rotate(180deg); }
        
        .section-body {
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s ease;
        }
        
        .section.open .section-body { max-height: 1000px; }
        .section-content { padding: 20px; }
        
        .attrs-grid {
            display: grid;
            grid-template-columns: repeat(5, 1fr);
            gap: 8px;
        }
        
        .attr-box {
            background: var(--paper);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 12px 4px;
            text-align: center;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }
        
        .attr-box:hover {
            border-color: currentColor;
            transform: translateY(-2px);
        }
        
        .attr-box:active { transform: scale(0.95); }
        
        .attr-label {
            font-size: 0.6rem;
            color: var(--text-muted);
            margin-bottom: 6px;
        }
        
        .attr-value {
            width: 100%;
            background: transparent;
            border: none;
            color: #fff;
            font-size: 1.4rem;
            font-weight: 700;
            text-align: center;
            font-family: 'Courier Prime', monospace;
        }
        
        .attr-roll {
            position: absolute;
            top: 2px;
            right: 2px;
            font-size: 0.7rem;
            opacity: 0.5;
        }
        
        .skill-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 12px 16px;
            margin-bottom: 8px;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .skill-item:hover {
            border-color: currentColor;
            background: rgba(255,255,255,0.05);
        }
        
        .skill-name { font-size: 0.9rem; }
        
        .skill-total {
            color: currentColor;
            font-weight: 700;
            font-size: 1.1rem;
        }
        
        .ritual-card {
            background: var(--paper);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 10px;
            cursor: pointer;
            transition: all 0.3s;
        }
        
        .ritual-card:hover { border-color: currentColor; }
        
        .ritual-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
        }
        
        .ritual-name {
            font-family: 'Cinzel', serif;
            font-size: 0.95rem;
            color: currentColor;
        }
        
        .ritual-cost {
            background: rgba(255,255,255,0.1);
            padding: 4px 10px;
            border-radius: 6px;
            font-size: 0.7rem;
        }
        
        .ritual-meta {
            display: flex;
            gap: 12px;
            font-size: 0.75rem;
            color: var(--text-muted);
            margin-bottom: 8px;
        }
        
        .ritual-desc {
            font-size: 0.85rem;
            color: #888;
            line-height: 1.4;
            max-height: 0;
            overflow: hidden;
            transition: max-height 0.3s;
        }
        
        .ritual-card.open .ritual-desc { max-height: 200px; }
        
        .ritual-actions {
            display: flex;
            gap: 8px;
            margin-top: 12px;
        }
        
        .ritual-btn {
            flex: 1;
            padding: 8px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            border-radius: 6px;
            color: var(--text);
            font-size: 0.75rem;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .ritual-btn:hover { border-color: currentColor; }
        
        .ritual-btn.cast {
            border-color: var(--energia);
            color: var(--energia-light);
        }
        
        .ritual-btn.danger {
            border-color: var(--sangue);
            color: var(--sangue-light);
        }
        
        .add-btn {
            width: 100%;
            padding: 14px;
            background: transparent;
            border: 2px dashed var(--border);
            border-radius: 10px;
            color: var(--text-muted);
            font-size: 0.8rem;
            letter-spacing: 1px;
            cursor: pointer;
            margin-top: 12px;
        }
        
        .add-btn:hover {
            border-color: currentColor;
            color: currentColor;
        }
        
        .notes-textarea {
            width: 100%;
            background: var(--paper);
            border: 1px solid var(--border);
            border-radius: 12px;
            color: var(--text);
            padding: 16px;
            font-size: 0.9rem;
            font-family: 'Courier Prime', monospace;
            resize: vertical;
            min-height: 100px;
        }
        
        .notes-textarea:focus {
            outline: none;
            border-color: currentColor;
        }
        
        .modal-panel {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.98);
            z-index: 1000;
            display: none;
            flex-direction: column;
        }
        
        .modal-panel.open {
            display: flex;
            animation: fadeIn 0.2s;
        }
        
        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px;
            border-bottom: 2px solid currentColor;
            background: var(--paper);
        }
        
        .modal-title {
            font-family: 'Cinzel', serif;
            font-size: 1.1rem;
            letter-spacing: 2px;
        }
        
        .modal-close {
            width: 40px;
            height: 40px;
            background: var(--surface);
            border: 1px solid var(--border);
            border-radius: 10px;
            color: var(--text);
            font-size: 1.5rem;
            cursor: pointer;
        }
        
        .modal-content {
            flex: 1;
            overflow-y: auto;
            padding: 16px;
            -webkit-overflow-scrolling: touch;
        }
        
        .dice-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }
        
        .dice-btn {
            aspect-ratio: 1;
            background: linear-gradient(145deg, var(--surface), var(--paper));
            border: 1px solid var(--border);
            border-radius: 12px;
            color: var(--text);
            font-family: 'Cinzel', serif;
            font-size: 1.1rem;
            cursor: pointer;
            transition: all 0.2s;
        }
        
        .dice-btn:hover {
            border-color: currentColor;
            transform: scale(1.05);
        }
        
        .dice-btn:active { transform: scale(0.95); }
        
        .dice-btn.advantage {
            border-color: var(--conhecimento-light);
            color: var(--conhecimento-light);
        }
        
        .dice-btn.disadvantage {
            border-color: var(--sangue-light);
            color: var(--sangue-light);
        }
        
        .dice-result {
            background: var(--paper);
            border: 2px solid currentColor;
            border-radius: 16px;
            padding: 30px;
            text-align: center;
            margin: 20px 0;
            position: relative;
            overflow: hidden;
        }
        
        .dice-result.critical {
            animation: pulse 0.5s 3;
            border-color: var(--sangue-light);
        }
        
        .result-number {
            font-size: 4rem;
            font-weight: 700;
            color: currentColor;
            line-height: 1;
            margin-bottom: 8px;
        }
        
        .result-label {
            color: var(--text-muted);
            font-size: 0.9rem;
        }
        
        .result-rolls {
            color: #555;
            font-size: 0.8rem;
            margin-top: 6px;
        }
        
        .history-list {
            border-top: 1px solid var(--border);
            padding-top: 16px;
        }
        
        .history-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #1a1a1a;
            font-size: 0.9rem;
        }
        
        .form-group { margin-bottom: 16px; }
        
        .form-label {
            display: block;
            color: var(--text-muted);
            font-size: 0.7rem;
            text-transform: uppercase;
            letter-spacing: 2px;
            margin-bottom: 8px;
        }
        
        .form-input, .form-select {
            width: 100%;
            background: var(--paper);
            border: 1px solid var(--border);
            border-radius: 12px;
            color: var(--text);
            padding: 14px;
            font-size: 1rem;
            font-family: 'Courier Prime', monospace;
        }
        
        .form-input:focus, .form-select:focus {
            outline: none;
            border-color: currentColor;
        }
        
        .form-row {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
        }
        
        .btn-primary {
            width: 100%;
            padding: 16px;
            background: linear-gradient(145deg, rgba(255,255,255,0.1), transparent);
            border: 2px solid currentColor;
            border-radius: 12px;
            color: currentColor;
            font-family: 'Cinzel', serif;
            font-size: 1rem;
